description: Bruno Wollmann's blog about Networking
opengraph: true
schema: true
twitter_cards: true
readmore: false
authorbox: false
toc: false
pager: true
post_meta:
  - date
  - categories
mainSections:
  - posts
customCSS:
  - css/custom.css

logo:
  image: /Logo.jpg
  title: Bruno Wollmann on Networking
  subtitle: Just another site about Networking

sidebar:
  home: right
  list: right
  single: false
  widgets:
    - recent
    - social
    - categories
    - taglist

widgets:
  recent_num: 5
  tags_counter: false
  social:
    linkedin: wollmannbruno
    github: wollmannbruno

style:
  vars:
    highlightColor: "#0288d1"
